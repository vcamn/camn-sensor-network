# File level variables
@ApiVersion = v1
@RequestedBy = Fleet.Api.Tests
@id = 95dd2e63-75e4-4167-9ad5-d759dacbc6c9
@stationId = 55bc2233-8663-45cc-ae71-0eb38c95a7eb

GET {{HostAddress}}/api/{{ApiVersion}}/devices

###

GET {{HostAddress}}/api/{{ApiVersion}}/devices/{{id}}

###

POST {{HostAddress}}/api/{{ApiVersion}}/devices
Content-Type: application/json

{
  "stationId": "{{stationId}}",
  "deviceStatusCode": "ACTIVE",
  "deviceIdentifier": "DEV-RPI-01",
  "deviceType": "RASPBERRY_PI_ZERO_2W"
} 

###

PUT {{HostAddress}}/api/{{ApiVersion}}/devices/{{id}}
Content-Type: application/json

{
  "id": "{{id}}",
  "deviceStatusCode": "ACTIVE",
  "deviceIdentifier": "DEV-RPI-0001",
  "deviceType": "Raspberry Pi Zero 2W",
  "serialNumber": "SN-ABC-123456",
  "macAddress": "00:1A:2B:3C:4D:5E",
  "firmwareVersion": "v1.2.3",
  "ioTHubDeviceId": null
}

###
